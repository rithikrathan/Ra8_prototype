root = true

# ───────── Default ─────────
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

indent_style = space
indent_size = 4
tab_width = 4

# ───────── C / C++ ─────────
[*.{c,cpp,h,hpp}]
indent_style = space
indent_size = 4

# ───────── Lua ─────────
[*.{lua}]
indent_style = space
indent_size = 4

# ───────── Java ─────────
[*.java]
indent_style = space
indent_size = 4

# ───────── JS / JSX / TS ─────────
[*.{js,jsx,ts,tsx}]
indent_style = space
indent_size = 4

# ───────── Python ─────────
[*.py]
indent_style = space
indent_size = 4

# ───────── Rust ─────────
[*.rs]
indent_style = space
indent_size = 4

# ───────── Go (tabs are standard) ─────────
[*.go]
indent_style = tab
tab_width = 4

# ───────── JSON / YAML (2 spaces common) ─────────
[*.json]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

# ───────── Markdown ─────────
[*.md]
trim_trailing_whitespace = false

# ───────── Makefile ─────────
[Makefile]
indent_style = tab
tab_width = 4
